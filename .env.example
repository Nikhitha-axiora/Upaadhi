# Upaadhi local environment

# API gateway
PORT=4000
IDENTITY_URL=http://localhost:4101
LISTING_URL=http://localhost:4102
FEED_URL=http://localhost:4103
TRUST_URL=http://localhost:4104

# Services
IDENTITY_PORT=4101
LISTING_PORT=4102
FEED_PORT=4103
TRUST_PORT=4104

# PostgreSQL
# When DATABASE_URL is unset, services use in-memory repositories for local development.
# Production/staging must set DATABASE_URL and run npm run migrate before service startup.
DATABASE_URL=postgres://upaadhi:upaadhi@localhost:5432/upaadhi

# Security
JWT_SECRET=change-this-to-a-long-random-production-secret
ACCESS_TOKEN_TTL_SECONDS=900
OTP_TTL_SECONDS=300
OTP_PEPPER=change-this-to-a-long-random-otp-pepper
