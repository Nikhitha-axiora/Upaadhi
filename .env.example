# Upaadhi local environment

# API gateway
PORT=4000
IDENTITY_URL=http://localhost:4101
LISTING_URL=http://localhost:4102
FEED_URL=http://localhost:4103
TRUST_URL=http://localhost:4104

# Services
IDENTITY_PORT=4101
LISTING_PORT=4102
FEED_PORT=4103
TRUST_PORT=4104

# PostgreSQL
# When DATABASE_URL is unset, services use in-memory repositories for local development.
# Production/staging must set DATABASE_URL and run npm run migrate before service startup.
DATABASE_URL=postgres://upaadhi:upaadhi@localhost:5432/upaadhi

# Security
# NOTE: In production the gateway refuses to start if JWT_SECRET / OTP_PEPPER
# are unset or left at their development defaults (fail-closed secret guard).
JWT_SECRET=change-this-to-a-long-random-production-secret
OTP_PEPPER=change-this-to-a-long-random-otp-pepper

# Sessions & tokens (short-lived access + rotating refresh)
ACCESS_TOKEN_TTL_SECONDS=600
REFRESH_TOKEN_TTL_SECONDS=2592000
OTP_TTL_SECONDS=300

# OTP brute-force defence (per-phone throttling + lockout)
OTP_WINDOW_SECONDS=900
OTP_MAX_PER_WINDOW=5
OTP_LOCK_AFTER_FAILURES=5
OTP_LOCK_SECONDS=900

# CORS allow-list (comma-separated origins). Unset = reflect any origin (dev only).
# CORS_ORIGINS=https://app.upaadhi.example,https://upaadhi.example

# Set NODE_ENV=production in real deployments to enforce the secret guard.
# NODE_ENV=production
